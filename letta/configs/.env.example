# =============================================================================
# Letta Server — Environment Variables
# =============================================================================
# Copy to .env and fill in your values. NEVER commit .env to git!
# Place alongside docker-compose.yml
# =============================================================================

# ── Required: Model Provider Credentials ───────────────────────────────────
# At least one provider is required
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ───────────────────────────────────────────────────────────────
# SQLite (default — good for single-server, simpler ops)
LETTA_DB_TYPE=sqlite
LETTA_DB_PATH=/data/letta.db

# PostgreSQL (production — use for multi-server, HA)
# LETTA_DB_TYPE=postgres
# LETTA_DB_URI=postgresql://letta:YOUR_PASSWORD@postgres-primary.internal:5432/letta?sslmode=require
# POSTGRES_PASSWORD=your-strong-password-here

# Connection pooling (postgres only)
# LETTA_DB_POOL_SIZE=20
# LETTA_DB_POOL_OVERFLOW=10

# ── Server Config ──────────────────────────────────────────────────────────
LETTA_HOST=0.0.0.0
LETTA_PORT=8283
LETTA_LOG_LEVEL=info

# ── Archival Memory Backend ────────────────────────────────────────────────
# LanceDB (default — embedded, no config needed)
LETTA_ARCHIVAL_BACKEND=lance

# Pinecone (production — managed vector DB)
# LETTA_ARCHIVAL_BACKEND=pinecone
# PINECONE_API_KEY=...
# PINECONE_ENVIRONMENT=us-east-1-aws
# PINECONE_INDEX_NAME=letta-archival

# ── Recall Memory Backend ──────────────────────────────────────────────────
# Redis (production — for recall memory at scale)
# LETTA_RECALL_BACKEND=redis
# REDIS_URI=redis://:YOUR_PASSWORD@redis.internal:6379/0
# REDIS_MAX_CONNECTIONS=50
