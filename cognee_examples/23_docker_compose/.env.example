# Cognee Docker Compose — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────
LLM_API_KEY=sk-your-api-key-here

# ── LLM Configuration ─────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_BASE=

# ── Embedding Configuration ───────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ── Database Credentials ──────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-in-production

POSTGRES_USER=cognee
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=cognee

# ── Resource Limits ───────────────────────────────────────────────────
NEO4J_HEAP_INIT=512m
NEO4J_HEAP_MAX=2g
NEO4J_PAGECACHE=1g
REDIS_MAXMEMORY=2gb

# ── Pipeline Tuning ───────────────────────────────────────────────────
COGNEE_CONCURRENCY=10
COGNEE_DISTRIBUTED=false
CACHE_TTL=3600

# ── API Server ────────────────────────────────────────────────────────
COGNEE_API_PORT=8000
CORS_ALLOWED_ORIGINS=*

# ── Authentication ────────────────────────────────────────────────────
AUTH_PROVIDER=api_key
API_KEYS=cognee_sk_change_me_in_production

# ── Observability (optional) ──────────────────────────────────────────
# OTEL_EXPORTER_ENDPOINT=https://api.honeycomb.io/v1/traces
# OTEL_EXPORTER_HEADERS=x-honeycomb-team=your-api-key
